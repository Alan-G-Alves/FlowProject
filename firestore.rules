rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function myUid() { return request.auth.uid; }

    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/platformUsers/$(myUid()))
        && get(/databases/$(database)/documents/platformUsers/$(myUid())).data.role == "superadmin"
        && get(/databases/$(database)/documents/platformUsers/$(myUid())).data.active == true;
    }

    function myCompanyId() {
      return get(/databases/$(database)/documents/userCompanies/$(myUid())).data.companyId;
    }

    function myCompanyUserDoc(companyId) {
      return get(/databases/$(database)/documents/companies/$(companyId)/users/$(myUid()));
    }

    function isCompanyAdmin(companyId) {
      return isSignedIn()
        && !isSuperAdmin()
        && exists(/databases/$(database)/documents/userCompanies/$(myUid()))
        && companyId == myCompanyId()
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(myUid()))
        && myCompanyUserDoc(companyId).data.role == "admin"
        && myCompanyUserDoc(companyId).data.active == true;
    }

    function isManager(companyId) {
      return isSignedIn()
        && !isSuperAdmin()
        && exists(/databases/$(database)/documents/userCompanies/$(myUid()))
        && companyId == myCompanyId()
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(myUid()))
        && myCompanyUserDoc(companyId).data.role == "gestor"
        && myCompanyUserDoc(companyId).data.active == true;
    }

    function isCoordinator(companyId) {
      return isSignedIn()
        && !isSuperAdmin()
        && exists(/databases/$(database)/documents/userCompanies/$(myUid()))
        && companyId == myCompanyId()
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(myUid()))
        && myCompanyUserDoc(companyId).data.role == "coordenador"
        && myCompanyUserDoc(companyId).data.active == true;
    }


    function isCoordenador(companyId) {
      return isSignedIn()
        && !isSuperAdmin()
        && exists(/databases/$(database)/documents/userCompanies/$(myUid()))
        && companyId == myCompanyId()
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(myUid()))
        && myCompanyUserDoc(companyId).data.role == "coordenador"
        && myCompanyUserDoc(companyId).data.active == true;
    }
    
    function isCompanyMember(companyId) {
      return isSignedIn()
        && !isSuperAdmin()
        && exists(/databases/$(database)/documents/userCompanies/$(myUid()))
        && companyId == myCompanyId()
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(myUid()))
        && myCompanyUserDoc(companyId).data.active == true;
    }

    function companyIsIndividual(companyId) {
      return exists(/databases/$(database)/documents/companies/$(companyId))
        && get(/databases/$(database)/documents/companies/$(companyId)).data.accountType == "individual";
    }

    function userRoleAllowedForCompany(companyId, uid) {
      return !companyIsIndividual(companyId)
        || request.resource.data.role == "tecnico"
        || (
          resource != null
          && uid == get(/databases/$(database)/documents/companies/$(companyId)).data.ownerUid
          && request.resource.data.role == resource.data.role
        );
    }

    // Campos conhecidos do documento companies/{companyId}/users/{uid}.
    //
    // Importante: para UPDATE, nÃ£o podemos exigir que o documento tenha *apenas* esses campos,
    // porque existem documentos legados com chaves extras. EntÃ£o, no UPDATE validamos apenas
    // as chaves que estÃ£o sendo alteradas/adicionadas/removidas.
    function userFieldsAllowedOnCreate() {
      return request.resource.data.keys().hasOnly([
        "name","role","teamId","teamIds","managedTeamIds",
        "email","emailLower","phone","active",
        "softSkills","hardSkills",
        "feedbackCount","number",
        "createdAt","createdBy",
        "photoURL","hourlyRate",
        "address","cpf","cnpj","birthDate","age",
        "attachments","onboarding"
      ]);
    }

    function userFieldsAllowedOnUpdate() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "name","role","teamId","teamIds","managedTeamIds",
        "email","emailLower","phone","active",
        "softSkills","hardSkills",
        "feedbackCount","number",
        "createdAt","createdBy",
        "photoURL","hourlyRate",
        "address","cpf","cnpj","birthDate","age",
        "attachments","onboarding"
      ]);
    }

    function roleValid() {
      return request.resource.data.role in ["admin","gestor","coordenador","tecnico"];
    }

    function nameValid() {
      return request.resource.data.name is string && request.resource.data.name.size() > 0;
    }

    function emailValid() {
      return request.resource.data.email is string && request.resource.data.email.size() > 0;
    }

    function phoneValid() {
      return request.resource.data.phone is string;
    }

    function addressOptionalValid() {
      return !("address" in request.resource.data)
        || request.resource.data.address is string;
    }

    function cpfOptionalValid() {
      return !("cpf" in request.resource.data)
        || request.resource.data.cpf is string;
    }

    function cnpjOptionalValid() {
      return !("cnpj" in request.resource.data)
        || request.resource.data.cnpj is string;
    }

    function birthDateOptionalValid() {
      return !("birthDate" in request.resource.data)
        || request.resource.data.birthDate is string;
    }

    function ageOptionalValid() {
      return !("age" in request.resource.data)
        || request.resource.data.age is int;
    }

    function attachmentsOptionalValid() {
      return !("attachments" in request.resource.data)
        || request.resource.data.attachments is list;
    }

    function activeValid() {
      return request.resource.data.active is bool;
    }


    function hourlyRateOptionalValid() {
      return !("hourlyRate" in request.resource.data)
        || request.resource.data.hourlyRate is number;
    }

    function createdAtOptionalValid() {
      return !("createdAt" in request.resource.data)
        || request.resource.data.createdAt is timestamp;
    }

    function createdByOptionalValid() {
      return !("createdBy" in request.resource.data)
        || (request.resource.data.createdBy is string && request.resource.data.createdBy.size() > 0);
    }

    function teamIdOptionalValid() {
      return !("teamId" in request.resource.data)
        || (request.resource.data.teamId is string);
    }

    function teamIdsOptionalValid() {
      return !("teamIds" in request.resource.data)
        || (request.resource.data.teamIds is list);
    }

    function managedTeamIdsOptionalValid() {
      return !("managedTeamIds" in request.resource.data)
        || (request.resource.data.managedTeamIds is list);
    }

    function userTeamsRuleValid() {
      // admin pode ter 0 equipes
      // técnico pode ter 0 equipes (quando a empresa ainda não cadastrou equipes)
      // demais devem ter >=1 equipe (teamIds ou teamId)
      return request.resource.data.role in ["admin","tecnico"]
        || (
          (("teamIds" in request.resource.data) && request.resource.data.teamIds.size() >= 1)
          || (("teamId" in request.resource.data) && request.resource.data.teamId.size() > 0)
        );
    }

    // valida se o técnico está APENAS em equipes administradas pelo gestor logado
    function teamsSubsetOfMyManaged(companyId) {
      // teamIds obrigatório para técnico (no fluxo do gestor)
      return ("teamIds" in request.resource.data)
        && request.resource.data.teamIds is list
        && request.resource.data.teamIds.size() >= 1
        && request.resource.data.teamIds.hasOnly(myCompanyUserDoc(companyId).data.managedTeamIds);
    }

    // platformUsers
    match /platformUsers/{uid} {
      allow read: if isSuperAdmin() || (isSignedIn() && uid == myUid());
      allow write: if false;
    }

    // userCompanies
    match /userCompanies/{uid} {
      allow read: if isSuperAdmin() || (isSignedIn() && uid == myUid());

      // master
      allow create, update: if isSuperAdmin()
        && request.resource.data.keys().hasOnly(["companyId"])
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0;

      // admin da empresa
      allow create, update: if !isSuperAdmin()
        && isCompanyAdmin(request.resource.data.companyId)
        && request.resource.data.keys().hasOnly(["companyId"])
        && request.resource.data.companyId is string
        && request.resource.data.companyId.size() > 0;

      // gestor pode vincular SOMENTE usuários à própria empresa (para técnicos que ele cria)
      allow create, update: if !isSuperAdmin()
        && isManager(request.resource.data.companyId)
        && request.resource.data.keys().hasOnly(["companyId"])
        && request.resource.data.companyId is string
        && request.resource.data.companyId == myCompanyId();

      allow delete: if false;
    }

    // companies
    match /companies/{companyId} {
      allow read: if isSuperAdmin() || (isSignedIn() && companyId == myCompanyId());

      // Master pode criar e também (importante) bloquear/desbloquear qualquer empresa
      allow create: if isSuperAdmin()
        && request.resource.data.keys().hasOnly(["name", "displayName", "cnpj", "cpf", "cpfHash", "accountType", "documentType", "active", "ownerUid", "ownerEmail", "planId", "planName", "planUserLimit", "planParticipantLimit", "planProjectLimit", "planPrice", "planAnnualPrice", "planBillingCycle", "planBillingPrice", "planInstallments", "planInstallmentValue", "planInstallmentPayments", "planUpdatedAt", "billing", "billingStartDate", "billingEndDate", "financialContactName", "financialContactEmail", "financialContactPhone", "billingDueDate", "financialUpdatedAt", "stripeCustomerId", "stripeSubscriptionId", "stripeCheckoutSessionId", "stripeStatus", "createdAt", "createdBy"])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.cnpj is string
        && ((("accountType" in request.resource.data) && request.resource.data.accountType == "individual") || request.resource.data.cnpj.size() > 0)
        && request.resource.data.active is bool
        && (!("accountType" in request.resource.data) || request.resource.data.accountType in ["individual"])
        && (!("documentType" in request.resource.data) || request.resource.data.documentType in ["cpf"])
        && (!("cpf" in request.resource.data) || request.resource.data.cpf is string)
        && (!("cpfHash" in request.resource.data) || request.resource.data.cpfHash is string)
        && (!("ownerUid" in request.resource.data) || request.resource.data.ownerUid is string)
        && (!("ownerEmail" in request.resource.data) || request.resource.data.ownerEmail is string)
        && (!("planId" in request.resource.data) || request.resource.data.planId in ["plan-1-20", "plan-21-40", "plan-41-60", "plan-61-80", "plan-81-100", "manager-start", "manager-pro", "manager-plus"])
        && (!("planName" in request.resource.data) || request.resource.data.planName is string)
        && (!("planUserLimit" in request.resource.data) || request.resource.data.planUserLimit in [3, 6, 11, 20, 40, 60, 80, 100])
        && (!("planParticipantLimit" in request.resource.data) || request.resource.data.planParticipantLimit in [2, 5, 10])
        && (!("planProjectLimit" in request.resource.data) || request.resource.data.planProjectLimit in [10, 20, 40])
        && (!("planPrice" in request.resource.data) || request.resource.data.planPrice is number)
        && (!("planAnnualPrice" in request.resource.data) || request.resource.data.planAnnualPrice is number)
        && (!("planBillingCycle" in request.resource.data) || request.resource.data.planBillingCycle in ["monthly", "annual"])
        && (!("planBillingPrice" in request.resource.data) || request.resource.data.planBillingPrice is number)
        && (!("planInstallments" in request.resource.data) || request.resource.data.planInstallments in [1, 2, 3, 4, 5])
        && (!("planInstallmentValue" in request.resource.data) || request.resource.data.planInstallmentValue is number)
        && (!("planInstallmentPayments" in request.resource.data) || (
          request.resource.data.planInstallmentPayments is map
          && request.resource.data.planInstallmentPayments.keys().hasOnly(["p1", "p2", "p3", "p4", "p5"])
          && (!("p1" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p1 is bool)
          && (!("p2" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p2 is bool)
          && (!("p3" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p3 is bool)
          && (!("p4" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p4 is bool)
          && (!("p5" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p5 is bool)
        ))
        && (!("planUpdatedAt" in request.resource.data) || request.resource.data.planUpdatedAt is timestamp)
        && (!("billing" in request.resource.data) || request.resource.data.billing is map)
        && (!("billingStartDate" in request.resource.data) || request.resource.data.billingStartDate is string)
        && (!("billingEndDate" in request.resource.data) || request.resource.data.billingEndDate is string)
        && (!("financialContactName" in request.resource.data) || request.resource.data.financialContactName is string)
        && (!("financialContactEmail" in request.resource.data) || request.resource.data.financialContactEmail is string)
        && (!("financialContactPhone" in request.resource.data) || request.resource.data.financialContactPhone is string)
        && (!("billingDueDate" in request.resource.data) || request.resource.data.billingDueDate is string)
        && (!("financialUpdatedAt" in request.resource.data) || request.resource.data.financialUpdatedAt is timestamp)
        && (!("stripeCustomerId" in request.resource.data) || request.resource.data.stripeCustomerId is string)
        && (!("stripeSubscriptionId" in request.resource.data) || request.resource.data.stripeSubscriptionId is string)
        && (!("stripeCheckoutSessionId" in request.resource.data) || request.resource.data.stripeCheckoutSessionId is string)
        && (!("stripeStatus" in request.resource.data) || request.resource.data.stripeStatus is string)
        && request.resource.data.createdBy == myUid();

      allow update: if isSuperAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["active"])
        && request.resource.data.active is bool;

      allow update: if isSuperAdmin()
        && request.resource.data.keys().hasOnly(["name", "displayName", "cnpj", "cpf", "cpfHash", "accountType", "documentType", "active", "ownerUid", "ownerEmail", "planId", "planName", "planUserLimit", "planParticipantLimit", "planProjectLimit", "planPrice", "planAnnualPrice", "planBillingCycle", "planBillingPrice", "planInstallments", "planInstallmentValue", "planInstallmentPayments", "planUpdatedAt", "billing", "billingStartDate", "billingEndDate", "financialContactName", "financialContactEmail", "financialContactPhone", "billingDueDate", "financialUpdatedAt", "stripeCustomerId", "stripeSubscriptionId", "stripeCheckoutSessionId", "stripeStatus", "createdAt", "createdBy", "number", "logoURL", "logoPath", "logoReportDataUrl", "reportPermissions", "projectTechPermissions", "activityNoteMinChars", "expenseObservationMinChars", "updatedAt"])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.cnpj is string
        && ((("accountType" in request.resource.data) && request.resource.data.accountType == "individual") || request.resource.data.cnpj.size() > 0)
        && request.resource.data.active is bool
        && (!("accountType" in request.resource.data) || request.resource.data.accountType in ["individual"])
        && (!("documentType" in request.resource.data) || request.resource.data.documentType in ["cpf"])
        && (!("cpf" in request.resource.data) || request.resource.data.cpf is string)
        && (!("cpfHash" in request.resource.data) || request.resource.data.cpfHash is string)
        && (!("ownerUid" in request.resource.data) || request.resource.data.ownerUid is string)
        && (!("ownerEmail" in request.resource.data) || request.resource.data.ownerEmail is string)
        && (!("planId" in request.resource.data) || request.resource.data.planId in ["plan-1-20", "plan-21-40", "plan-41-60", "plan-61-80", "plan-81-100", "manager-start", "manager-pro", "manager-plus"])
        && (!("planName" in request.resource.data) || request.resource.data.planName is string)
        && (!("planUserLimit" in request.resource.data) || request.resource.data.planUserLimit in [3, 6, 11, 20, 40, 60, 80, 100])
        && (!("planParticipantLimit" in request.resource.data) || request.resource.data.planParticipantLimit in [2, 5, 10])
        && (!("planProjectLimit" in request.resource.data) || request.resource.data.planProjectLimit in [10, 20, 40])
        && (!("planPrice" in request.resource.data) || request.resource.data.planPrice is number)
        && (!("planAnnualPrice" in request.resource.data) || request.resource.data.planAnnualPrice is number)
        && (!("planBillingCycle" in request.resource.data) || request.resource.data.planBillingCycle in ["monthly", "annual"])
        && (!("planBillingPrice" in request.resource.data) || request.resource.data.planBillingPrice is number)
        && (!("planInstallments" in request.resource.data) || request.resource.data.planInstallments in [1, 2, 3, 4, 5])
        && (!("planInstallmentValue" in request.resource.data) || request.resource.data.planInstallmentValue is number)
        && (!("planInstallmentPayments" in request.resource.data) || (
          request.resource.data.planInstallmentPayments is map
          && request.resource.data.planInstallmentPayments.keys().hasOnly(["p1", "p2", "p3", "p4", "p5"])
          && (!("p1" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p1 is bool)
          && (!("p2" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p2 is bool)
          && (!("p3" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p3 is bool)
          && (!("p4" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p4 is bool)
          && (!("p5" in request.resource.data.planInstallmentPayments) || request.resource.data.planInstallmentPayments.p5 is bool)
        ))
        && (!("planUpdatedAt" in request.resource.data) || request.resource.data.planUpdatedAt is timestamp)
        && (!("billing" in request.resource.data) || request.resource.data.billing is map)
        && (!("billingStartDate" in request.resource.data) || request.resource.data.billingStartDate is string)
        && (!("billingEndDate" in request.resource.data) || request.resource.data.billingEndDate is string)
        && (!("financialContactName" in request.resource.data) || request.resource.data.financialContactName is string)
        && (!("financialContactEmail" in request.resource.data) || request.resource.data.financialContactEmail is string)
        && (!("financialContactPhone" in request.resource.data) || request.resource.data.financialContactPhone is string)
        && (!("billingDueDate" in request.resource.data) || request.resource.data.billingDueDate is string)
        && (!("financialUpdatedAt" in request.resource.data) || request.resource.data.financialUpdatedAt is timestamp)
        && (!("stripeCustomerId" in request.resource.data) || request.resource.data.stripeCustomerId is string)
        && (!("stripeSubscriptionId" in request.resource.data) || request.resource.data.stripeSubscriptionId is string)
        && (!("stripeCheckoutSessionId" in request.resource.data) || request.resource.data.stripeCheckoutSessionId is string)
        && (!("stripeStatus" in request.resource.data) || request.resource.data.stripeStatus is string)
        && (!("number" in request.resource.data) || request.resource.data.number is int)
        && (!("activityNoteMinChars" in request.resource.data) || (request.resource.data.activityNoteMinChars is int && request.resource.data.activityNoteMinChars >= 0 && request.resource.data.activityNoteMinChars <= 1000))
        && (!("expenseObservationMinChars" in request.resource.data) || (request.resource.data.expenseObservationMinChars is int && request.resource.data.expenseObservationMinChars >= 0 && request.resource.data.expenseObservationMinChars <= 1000));

      allow update: if isCompanyAdmin(companyId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["displayName", "logoURL", "logoPath", "logoReportDataUrl", "reportPermissions", "projectTechPermissions", "activityNoteMinChars", "expenseObservationMinChars", "updatedAt"])
        && (!("displayName" in request.resource.data) || request.resource.data.displayName is string)
        && (!("logoURL" in request.resource.data) || request.resource.data.logoURL is string)
        && (!("logoPath" in request.resource.data) || request.resource.data.logoPath is string)
        && (!("logoReportDataUrl" in request.resource.data) || request.resource.data.logoReportDataUrl is string)
        && (!("reportPermissions" in request.resource.data) || request.resource.data.reportPermissions is map)
        && (!("projectTechPermissions" in request.resource.data) || request.resource.data.projectTechPermissions is map)
        && (!("activityNoteMinChars" in request.resource.data) || (request.resource.data.activityNoteMinChars is int && request.resource.data.activityNoteMinChars >= 0 && request.resource.data.activityNoteMinChars <= 1000))
        && (!("expenseObservationMinChars" in request.resource.data) || (request.resource.data.expenseObservationMinChars is int && request.resource.data.expenseObservationMinChars >= 0 && request.resource.data.expenseObservationMinChars <= 1000))
        && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);

      allow update: if (isManager(companyId) || isCoordinator(companyId) || isCoordenador(companyId))
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["projectTechPermissions", "updatedAt"])
        && (!("projectTechPermissions" in request.resource.data) || request.resource.data.projectTechPermissions is map)
        && (!("updatedAt" in request.resource.data) || request.resource.data.updatedAt is timestamp);

      allow delete: if false;

      match /billings/{billingId} {
        allow read: if isSuperAdmin();
        allow create, update: if isSuperAdmin();
        allow delete: if false;
      }

      // teams
      match /teams/{teamId} {
        allow read: if isSuperAdmin() || isCompanyMember(companyId);

        allow create, update: if isSuperAdmin()
          && request.resource.data.keys().hasOnly(["name","active","number","createdAt","createdBy"])
          && request.resource.data.name is string && request.resource.data.name.size() > 0
          && request.resource.data.active is bool;

        allow create, update: if !isSuperAdmin()
          && isCompanyAdmin(companyId)
          && request.resource.data.keys().hasOnly(["name","active","number","createdAt","createdBy"])
          && request.resource.data.name is string && request.resource.data.name.size() > 0
          && request.resource.data.active is bool;

        allow delete: if isSuperAdmin() || isCompanyAdmin(companyId);
      }

// counters (IDs sequenciais por empresa)
match /counters/{counterId} {
  allow read: if isSuperAdmin()
    || isCompanyAdmin(companyId)
    || isManager(companyId)
          || isCoordinator(companyId)
    || isCoordenador(companyId);

  // Apenas contador de projetos
  allow create: if (isCompanyAdmin(companyId) || isManager(companyId)
          || isCoordinator(companyId) || isCoordenador(companyId))
    && counterId in ["projects","techs"]
    && request.resource.data.keys().hasOnly(["next"])
    && request.resource.data.next is int
    && request.resource.data.next == 2;

  allow update: if (isCompanyAdmin(companyId) || isManager(companyId)
          || isCoordinator(companyId) || isCoordenador(companyId))
    && counterId in ["projects","techs"]
    && request.resource.data.keys().hasOnly(["next"])
    && request.resource.data.next is int
    && request.resource.data.next == resource.data.next + 1;

  allow delete: if false;
}
      // users
      match /users/{uid} {
        // IMPORTANTE: Apenas membros da mesma empresa podem ler usuários
        allow read: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || (isSignedIn() && uid == myUid() && companyId == myCompanyId());

        function userWriteValid() {
          return ((resource == null && userFieldsAllowedOnCreate()) || (resource != null && userFieldsAllowedOnUpdate()))
             && nameValid()
             && roleValid()
             && emailValid()
             && phoneValid()
             && addressOptionalValid()
            && cpfOptionalValid()
            && cnpjOptionalValid()
            && birthDateOptionalValid()
            && ageOptionalValid()
            && hourlyRateOptionalValid()
            && activeValid()
            && createdAtOptionalValid()
            && createdByOptionalValid()
            && teamIdOptionalValid()
            && teamIdsOptionalValid()
            && managedTeamIdsOptionalValid()
            && attachmentsOptionalValid()
            && userTeamsRuleValid();
        }

        // master / admin da empresa
        allow create, update: if (isSuperAdmin() || isCompanyAdmin(companyId))
          && userRoleAllowedForCompany(companyId, uid)
          && userWriteValid();

        allow update: if isSuperAdmin()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["active"])
          && request.resource.data.active is bool;


        // ✅ self-update (perfil): qualquer usuário pode atualizar APENAS seus próprios campos de perfil
        allow update: if isSignedIn()
          && uid == myUid()
          && companyId == myCompanyId()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["onboarding"])
            && userFieldsAllowedOnUpdate();

        allow update: if isSignedIn()
          && uid == myUid()
          && companyId == myCompanyId()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["name","phone","photoURL","hourlyRate","address","birthDate","age","onboarding"])
            && ((resource == null && userFieldsAllowedOnCreate()) || (resource != null && userFieldsAllowedOnUpdate()))
            && nameValid()
            && phoneValid()
              && addressOptionalValid()
              && birthDateOptionalValid()
            && ageOptionalValid()
            && hourlyRateOptionalValid();

        // gestor: pode criar/atualizar técnico (técnico pertence à empresa, não ao escopo do gestor)
        allow create, update: if isManager(companyId)
          && request.resource.data.role == "tecnico"
          && userWriteValid();

        // coordenador: mesmas permissões do gestor
        allow create, update: if isCoordinator(companyId)
          && request.resource.data.role == "tecnico"
          && userWriteValid();

        

        // feedbacks do técnico
        match /feedbacks/{feedbackId} {
          allow read: if isSuperAdmin()
            || isCompanyAdmin(companyId)
            || isManager(companyId)
            || isCoordinator(companyId)
            || (isSignedIn() && uid == myUid() && companyId == myCompanyId());

          allow create: if isCompanyAdmin(companyId)
            || isManager(companyId)
            || isCoordinator(companyId);

          allow update, delete: if false;
        }

allow delete: if false;
      }


      // clients
      match /clients/{clientId} {
        allow read: if isSuperAdmin() || isCompanyMember(companyId);

        // Perfis que gerenciam clientes (mesmo grupo que gerencia técnicos)
        allow create, update, delete: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId);

        // (validação leve) — evita campos inesperados
        function clientFieldsAllowed(){
          return request.resource.data.keys().hasOnly([
            "number","name","nameLower","cpfCnpj","address","phone","email",
            "keyUserName","keyUserEmail","keyUserPhone",
            "photoURL","active","createdAt","createdBy","updatedAt","updatedBy"
          ]);
        }

        allow create, update: if (isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId))
          && clientFieldsAllowed()
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.active is bool;
      }

      // projects (NOVO)
      match /projects/{projectId} {
        allow read: if isSuperAdmin() || isCompanyMember(companyId);
        
        allow create: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId);
        
        allow update: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId);
        
        allow delete: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId);
      }

      // tasks (FUTURO - Sprint 2)
      match /tasks/{taskId} {
        allow read: if isSuperAdmin() || isCompanyMember(companyId);
        
        allow create: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId);
        
        allow update: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId)
          || (isSignedIn() && companyId == myCompanyId()); // técnico pode atualizar próprias tarefas
        
        allow delete: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId);
      }

      // activities (workspace de projetos)
      match /activities/{activityId} {
        allow read: if isSuperAdmin() || isCompanyMember(companyId);

        allow create: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId)
          || (isSignedIn() && companyId == myCompanyId()); // tecnico tambem pode incluir (dia unico)

        allow update: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId)
          || (isSignedIn() && companyId == myCompanyId()); // tecnico pode preencher inicio/fim/obs

        allow delete: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId);
      }

      // expenses (despesas do projeto)
      match /expenses/{expenseId} {
        function expenseFieldsAllowed() {
          return request.resource.data.keys().hasOnly([
            "projectId","projectName",
            "clientId","clientName",
            "taskId","taskName",
            "activityId","activityName","workDate",
            "type","observation","amount",
            "chargedToClient",
            "status",
            "receipt",
            "source",
            "companyId",
            "techUid","techName",
            "managerUid","managerName",
            "coordinatorUid","coordinatorName",
            "createdBy","createdByName","createdByRole",
            "approvedBy","approvedByName","approvedByEmail","approvedByRole","approvedAt",
            "rejectedBy","rejectedByName","rejectedByRole","rejectedAt","rejectionReason",
            "updatedAt","updatedBy",
            "createdAt"
          ]);
        }

        function expenseReceiptValid() {
          return !("receipt" in request.resource.data)
            || request.resource.data.receipt is map;
        }

        function expenseTypeValid() {
          return request.resource.data.type in ["alimentacao","trajeto","estadia","outras"];
        }

        function expenseStatusValid() {
          return request.resource.data.status in ["pending","approved","rejected"];
        }

        function expenseObservationMinChars() {
          return ("expenseObservationMinChars" in get(/databases/$(database)/documents/companies/$(companyId)).data)
            && get(/databases/$(database)/documents/companies/$(companyId)).data.expenseObservationMinChars is int
            ? get(/databases/$(database)/documents/companies/$(companyId)).data.expenseObservationMinChars
            : 10;
        }

        function expenseBaseValid() {
          return expenseFieldsAllowed()
            && request.resource.data.projectId is string
            && request.resource.data.projectId.size() > 0
            && request.resource.data.type is string
            && expenseTypeValid()
            && request.resource.data.observation is string
            && request.resource.data.observation.size() >= expenseObservationMinChars()
            && request.resource.data.amount is number
            && request.resource.data.amount > 0
            && request.resource.data.chargedToClient is bool
            && request.resource.data.source in ["activity","manual"]
            && request.resource.data.createdBy is string
            && request.resource.data.createdBy.size() > 0
            && request.resource.data.createdByName is string
            && request.resource.data.createdByRole is string
            && request.resource.data.projectName is string
            && request.resource.data.status is string
            && expenseStatusValid()
            && expenseReceiptValid();
        }

        function canReviewExpense() {
          return isSuperAdmin()
            || isCompanyAdmin(companyId)
            || (
              (isManager(companyId) || isCoordinator(companyId) || isCoordenador(companyId))
              && (
                resource.data.createdBy == myUid()
                || (("createdByRole" in resource.data) && resource.data.createdByRole == "tecnico")
              )
            );
        }

        function expenseReviewFieldsValid() {
          return request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "status", "chargedToClient",
              "approvedBy", "approvedByName", "approvedByEmail", "approvedByRole", "approvedAt",
              "rejectedBy", "rejectedByName", "rejectedByRole", "rejectedAt", "rejectionReason",
              "updatedAt", "updatedBy"
            ])
            && resource.data.status == "pending"
            && request.resource.data.status in ["approved", "rejected"]
            && request.resource.data.chargedToClient is bool
            && request.resource.data.updatedBy == myUid();
        }

        allow read: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || (
            (isManager(companyId) || isCoordinator(companyId) || isCoordenador(companyId))
            && (
              resource.data.createdBy == myUid()
              || (("createdByRole" in resource.data) && resource.data.createdByRole == "tecnico")
            )
          )
          || (isSignedIn() && companyId == myCompanyId() && resource.data.createdBy == myUid());

        allow create: if (isSuperAdmin()
          || isCompanyAdmin(companyId)
          || isManager(companyId)
          || isCoordinator(companyId)
          || isCoordenador(companyId)
          || isCompanyMember(companyId))
          && expenseBaseValid()
          && request.resource.data.createdBy == myUid()
          && request.resource.data.status == "pending";

        allow update: if (isSuperAdmin()
          || isCompanyAdmin(companyId)
          || (
            (isManager(companyId) || isCoordinator(companyId) || isCoordenador(companyId))
            && (
              resource.data.createdBy == myUid()
              || (("createdByRole" in resource.data) && resource.data.createdByRole == "tecnico")
            )
          ))
          && expenseBaseValid();

        allow update: if canReviewExpense()
          && expenseReviewFieldsValid();

        allow update: if isCompanyMember(companyId)
          && resource.data.createdBy == myUid()
          && resource.data.status == "pending"
          && request.resource.data.status == "pending"
          && expenseBaseValid();

        allow delete: if false;
      }

      // notifications
      match /reminders/{reminderId} {
        allow read: if isCompanyMember(companyId)
          && resource.data.recipientUid == myUid();

        allow create: if isCompanyMember(companyId)
          && request.resource.data.keys().hasOnly([
            "recipientUid", "recipientName", "recipientSummary",
            "dueDate", "noteColor", "message",
            "viewed", "viewedAt", "viewedBy",
            "createdBy", "createdByName", "createdByRole",
            "createdAt", "updatedAt", "updatedBy"
          ])
          && request.resource.data.createdBy == myUid()
          && request.resource.data.updatedBy == myUid()
          && request.resource.data.recipientUid is string
          && request.resource.data.recipientUid.size() > 0
          && request.resource.data.recipientName is string
          && request.resource.data.recipientSummary is string
          && request.resource.data.dueDate is string
          && request.resource.data.dueDate.size() == 10
          && request.resource.data.noteColor is string
          && request.resource.data.noteColor in ["sun", "mint", "rose", "sky", "lavender"]
          && request.resource.data.message is string
          && request.resource.data.message.size() >= 4
          && request.resource.data.viewed == false
          && request.resource.data.viewedBy is string
          && request.resource.data.createdByName is string
          && request.resource.data.createdByRole is string
          && (
            request.resource.data.recipientUid == myUid()
            || isCompanyAdmin(companyId)
            || isManager(companyId)
          );

        allow update: if isCompanyMember(companyId)
          && resource.data.recipientUid == myUid()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["viewed", "viewedAt", "viewedBy", "updatedAt", "updatedBy"])
          && request.resource.data.viewed == true
          && request.resource.data.viewedBy == myUid()
          && request.resource.data.updatedBy == myUid()
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.viewedAt is timestamp;

        allow delete: if isCompanyMember(companyId)
          && (
            resource.data.recipientUid == myUid()
            || resource.data.createdBy == myUid()
            || isCompanyAdmin(companyId)
            || isManager(companyId)
          );
      }

      match /notifications/{notificationId} {
        allow read: if isCompanyMember(companyId)
          && resource.data.recipientUid == myUid();

        allow create: if isCompanyMember(companyId)
          && request.resource.data.keys().hasOnly([
            "recipientUid", "type", "title", "message", "entityType", "entityId",
            "projectId", "activityId", "taskId", "read", "createdAt",
            "createdBy", "createdByName", "createdByEmail"
          ])
          && request.resource.data.recipientUid is string
          && request.resource.data.recipientUid.size() > 0
          && request.resource.data.type is string
          && request.resource.data.title is string
          && request.resource.data.message is string
          && request.resource.data.entityType is string
          && request.resource.data.entityId is string
          && request.resource.data.projectId is string
          && request.resource.data.activityId is string
          && request.resource.data.taskId is string
          && request.resource.data.read == false
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdBy is string
          && request.resource.data.createdByName is string
          && request.resource.data.createdByEmail is string;

        allow update: if isCompanyMember(companyId)
          && resource.data.recipientUid == myUid()
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(["read", "readAt"])
          && request.resource.data.read is bool
          && (!("readAt" in request.resource.data) || request.resource.data.readAt is timestamp);

        allow delete: if false;
      }

      // LGPD: configuracoes, aceites e solicitacoes por empresa
      match /lgpd/{lgpdDocId} {
        allow read: if isSuperAdmin() || isCompanyMember(companyId);

        allow create, update: if (isSuperAdmin() || isCompanyAdmin(companyId))
          && lgpdDocId == "settings"
          && request.resource.data.keys().hasOnly([
            "version", "dpoName", "dpoEmail",
            "privacySummary", "termsSummary",
            "updatedAt", "updatedBy"
          ])
          && request.resource.data.version is string
          && request.resource.data.version.size() > 0
          && request.resource.data.dpoName is string
          && request.resource.data.dpoEmail is string
          && request.resource.data.privacySummary is string
          && request.resource.data.privacySummary.size() >= 10
          && request.resource.data.termsSummary is string
          && request.resource.data.termsSummary.size() >= 10
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedBy == myUid();

        allow delete: if false;
      }

      match /lgpdConsents/{uid} {
        allow read: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || (isSignedIn() && companyId == myCompanyId() && uid == myUid());

        allow create, update: if isSignedIn()
          && companyId == myCompanyId()
          && uid == myUid()
          && request.resource.data.keys().hasOnly([
            "uid", "email", "name", "role",
            "version", "accepted", "acceptedAt", "userAgent"
          ])
          && request.resource.data.uid == myUid()
          && request.resource.data.email is string
          && request.resource.data.name is string
          && request.resource.data.role is string
          && request.resource.data.version is string
          && request.resource.data.version.size() > 0
          && request.resource.data.accepted == true
          && request.resource.data.acceptedAt is timestamp
          && request.resource.data.userAgent is string;

        allow delete: if false;
      }

      match /lgpdVersions/{versionId} {
        allow read: if isSuperAdmin() || isCompanyAdmin(companyId);

        allow create: if (isSuperAdmin() || isCompanyAdmin(companyId))
          && request.resource.data.keys().hasOnly([
            "version", "previousVersion", "dpoName", "dpoEmail",
            "privacySummary", "termsSummary", "publishedAt",
            "publishedBy", "publishedByEmail"
          ])
          && request.resource.data.version is string
          && request.resource.data.version.size() > 0
          && request.resource.data.previousVersion is string
          && request.resource.data.dpoName is string
          && request.resource.data.dpoEmail is string
          && request.resource.data.privacySummary is string
          && request.resource.data.privacySummary.size() >= 10
          && request.resource.data.termsSummary is string
          && request.resource.data.termsSummary.size() >= 10
          && request.resource.data.publishedAt is timestamp
          && request.resource.data.publishedBy == myUid()
          && request.resource.data.publishedByEmail is string;

        allow update, delete: if false;
      }

      match /lgpdRequests/{requestId} {
        allow read: if isSuperAdmin()
          || isCompanyAdmin(companyId)
          || (isSignedIn() && companyId == myCompanyId() && resource.data.createdBy == myUid());

        allow create: if isCompanyMember(companyId)
          && request.resource.data.keys().hasOnly([
            "type", "typeLabel", "description", "status",
            "createdBy", "createdByName", "createdByEmail", "createdAt",
            "updatedAt", "updatedBy"
          ])
          && request.resource.data.type in ["access", "correction", "export", "deletion"]
          && request.resource.data.typeLabel is string
          && request.resource.data.description is string
          && request.resource.data.description.size() >= 10
          && request.resource.data.status == "open"
          && request.resource.data.createdBy == myUid()
          && request.resource.data.createdByName is string
          && request.resource.data.createdByEmail is string
          && request.resource.data.createdAt is timestamp
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedBy == myUid();

        allow update: if (isSuperAdmin() || isCompanyAdmin(companyId))
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "status", "updatedAt", "updatedBy", "closedAt"
          ])
          && request.resource.data.status in ["open", "reviewing", "closed"]
          && request.resource.data.updatedAt is timestamp
          && request.resource.data.updatedBy == myUid()
          && (!("closedAt" in request.resource.data)
            || request.resource.data.closedAt == null
            || request.resource.data.closedAt is timestamp);

        allow delete: if false;
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }
  }
}
