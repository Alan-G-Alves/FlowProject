rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function myCompanyId() {
      return firestore.get(/databases/(default)/documents/userCompanies/$(request.auth.uid)).data.companyId;
    }

    function myRole() {
      // role do usuário logado dentro da empresa
      return firestore.get(/databases/(default)/documents/companies/$(myCompanyId())/users/$(request.auth.uid)).data.role;
    }

    function canManageUsers() {
      return myRole() in ['admin', 'gestor', 'coordenador', 'superadmin'];
    }

    function targetExistsInMyCompany(targetUid) {
      return firestore.get(/databases/(default)/documents/companies/$(myCompanyId())/users/$(targetUid)).data.role is string;
    }

    // Avatares (SEM extensão): avatars/{uid}
    match /avatars/{targetUid} {
      allow read: if signedIn();

      // ✅ qualquer usuário logado pode trocar o PRÓPRIO avatar
      allow write: if signedIn()
        && targetUid == request.auth.uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // ✅ admin/gestor/coordenador podem trocar avatar de usuários da MESMA empresa
      allow write: if signedIn()
        && canManageUsers()
        && targetExistsInMyCompany(targetUid)
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    
    // Fotos de Clientes (SEM extensão): clientPhotos/{companyId}/{clientId}
    // Anexos de usuÃ¡rios: userAttachments/{companyId}/{targetUid}/{fileName}
    //
    // Nota: nÃ£o exigimos que o doc do usuÃ¡rio alvo exista no Firestore para permitir o upload,
    // pois no fluxo de criaÃ§Ã£o ele pode ainda nÃ£o ter sido gravado/propagado (causando 403).
    // A proteÃ§Ã£o principal aqui Ã©: estar autenticado + companyId do path == minha empresa
    // + (admin/gestor/coordenador OU o prÃ³prio usuÃ¡rio).
    match /userAttachments/{companyId}/{targetUid}/{fileName} {
      allow read: if signedIn()
        && companyId == myCompanyId()
        && (canManageUsers() || targetUid == request.auth.uid);

      allow create, update: if signedIn()
        && companyId == myCompanyId()
        && (canManageUsers() || targetUid == request.auth.uid)
        && request.resource.size < 8 * 1024 * 1024
        && (
          request.resource.contentType == 'application/pdf'
          || request.resource.contentType == 'application/msword'
          || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
          || request.resource.contentType.matches('image/.*')
        );

      allow delete: if signedIn()
        && companyId == myCompanyId()
        && (canManageUsers() || targetUid == request.auth.uid);
    }

    match /expenseReceipts/{companyId}/{expenseId}/{fileName} {
      allow read: if signedIn()
        && companyId == myCompanyId();

      allow create, update: if signedIn()
        && companyId == myCompanyId()
        && request.resource.size < 8 * 1024 * 1024
        && (
          request.resource.contentType == 'application/pdf'
          || request.resource.contentType.matches('image/.*')
        );

      allow delete: if signedIn()
        && companyId == myCompanyId()
        && canManageUsers();
    }

    match /clientPhotos/{companyId}/{clientId} {
      // qualquer usuário autenticado da mesma empresa pode ver a foto do cliente
      allow read: if signedIn();

      // upload/atualização da foto do cliente (2MB)
      // OBS: não dependemos de role aqui para evitar 403 por inconsistência de perfil;
      // quem pode criar/editar clientes continua controlado no Firestore.
      allow create, update: if signedIn()
        && companyId.size() > 0
        && clientId.size() > 0
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // delete somente para quem pode gerenciar (mantém mais seguro)
      allow delete: if signedIn()
        && companyId.size() > 0
        && clientId.size() > 0
        && canManageUsers();
    }


    // Logo da empresa: companyLogos/{companyId}/brandLogo
    match /companyLogos/{companyId}/{fileName} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && companyId == myCompanyId()
        && myRole() == 'admin'
        && fileName == 'brandLogo'
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      allow delete: if signedIn()
        && companyId == myCompanyId()
        && myRole() == 'admin';
    }

// Upload temporário de avatar enquanto o usuário ainda NÃO existe em companies/{companyId}/users/{uid}
    // Caminho: tempAvatars/{companyId}/{uploaderUid}/{tempId}
    match /tempAvatars/{companyId}/{uploaderUid}/{tempId} {
      // TEMP upload: permite apenas o próprio uploader (evita depender de Firestore get() aqui)
      allow read: if signedIn() && uploaderUid == request.auth.uid;

      // Criar/atualizar o temp avatar (limitado a imagem e 2MB)
      allow create, update: if signedIn()
        && uploaderUid == request.auth.uid
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');

      // Remover o temp avatar (ex.: cancelar modal)
      allow delete: if signedIn() && uploaderUid == request.auth.uid;
    }

    // Contratos de Projetos (PDF): projectContracts/{companyId}/{projectId}/{fileName}
    match /projectContracts/{companyId}/{projectId}/{fileName} {
      allow read: if signedIn();

      allow create, update: if signedIn()
        && companyId.size() > 0
        && projectId.size() > 0
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';

      allow delete: if signedIn()
        && companyId.size() > 0
        && projectId.size() > 0
        && canManageUsers();
    }



    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
